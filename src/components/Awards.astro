---
import { awards } from "../data/content";
---

<section id="awards" class="py-10 md:py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="section-title animate-on-scroll text-xl md:text-3xl">获奖证书</h2>
    <p class="section-subtitle animate-on-scroll hidden md:block">// awards</p>

    <div class="grid grid-cols-4 lg:grid-cols-4 gap-2 md:gap-6">
      {awards.map((award, i) => (
        <div class={`glow-card animate-on-scroll delay-${(i + 1) * 100}`}>
          <div class="glow-card-inner overflow-hidden aspect-[4/3] md:aspect-auto relative">
            <div class="absolute inset-0 md:relative md:h-64 overflow-hidden">
              <img
                src={award.image}
                alt={award.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>

            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-1.5 md:relative md:bg-none md:from-transparent md:p-4 text-center">
              <h3 class="font-bold text-text mb-0 md:mb-1 text-[9px] md:text-base leading-tight">{award.title}</h3>
              <p class="text-text-secondary text-sm hidden md:block">{award.issuer}</p>
              {award.date && <p class="font-mono text-text-muted text-xs mt-1 hidden md:block">{award.date}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
