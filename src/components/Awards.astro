---
import { awards } from "../data/content";
---

<section id="awards" class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="section-title animate-on-scroll">获奖证书</h2>
    <p class="section-subtitle animate-on-scroll">// awards</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {awards.map((award, i) => (
        <div class={`glow-card animate-on-scroll delay-${(i + 1) * 100}`}>
          <div class="glow-card-inner overflow-hidden">
            <div class="h-64 overflow-hidden">
              <img
                src={award.image}
                alt={award.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>

            <div class="p-4 text-center">
              <h3 class="font-bold text-text mb-1">{award.title}</h3>
              <p class="text-text-secondary text-sm">{award.issuer}</p>
              {award.date && <p class="font-mono text-text-muted text-xs mt-1">{award.date}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
