---
import { portfolioCategories, portfolioItems } from "../data/content";
---

<section id="portfolio" class="py-10 md:py-20 px-4 section-alt">
  <div class="max-w-6xl mx-auto">
    <h2 class="section-title animate-on-scroll text-xl md:text-3xl">作品集</h2>
    <p class="section-subtitle animate-on-scroll hidden md:block">// portfolio</p>

    <div class="flex-wrap justify-center gap-3 mb-10 animate-on-scroll hidden md:flex">
      {portfolioCategories.map((cat, i) => (
        <button class={`filter-btn ${i === 0 ? "active" : ""}`} data-category={cat}>
          {cat}
        </button>
      ))}
    </div>

    <div id="portfolio-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-6">
      {portfolioItems.length > 0 ? (
        portfolioItems.map((item, i) => (
          <div
            class={`portfolio-item glow-card animate-on-scroll delay-${(i + 1) * 100} cursor-pointer`}
            data-category={item.category}
            data-url={item.demoUrl || item.link}
            data-external={item.link ? "true" : "false"}
          >
            <div class="glow-card-inner overflow-hidden aspect-[4/3] md:aspect-auto relative md:flex md:flex-col">
              {item.bilibiliId ? (
                <div class="aspect-video">
                  <iframe
                    src={`https://player.bilibili.com/player.html?bvid=${item.bilibiliId}&page=1&high_quality=1`}
                    class="w-full h-full"
                    allowfullscreen
                    loading="lazy"
                    title={item.title}
                  ></iframe>
                </div>
              ) : item.image ? (
                <div class="absolute inset-0 md:relative md:h-48 overflow-hidden">
                  <img
                    src={item.image}
                    alt={item.title}
                    class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="absolute inset-0 md:relative md:h-48 img-placeholder">
                  <span class="font-mono text-xs">work_{String(i + 1).padStart(2, "0")}</span>
                </div>
              )}

              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-1.5 md:relative md:bg-none md:from-transparent md:p-5">
                <h3 class="font-bold text-primary md:text-text text-xs md:text-base md:mb-2">{item.title}</h3>
                <p class="text-text-secondary text-sm mb-3 hidden md:block">{item.description}</p>
                <span class="tag hidden md:inline">{item.category}</span>

                {(item.link || item.demoUrl) && (
                  <a
                    href={item.demoUrl || item.link}
                    target={item.link ? "_blank" : undefined}
                    rel={item.link ? "noopener noreferrer" : undefined}
                    class="mt-3 text-primary text-sm font-medium hover:underline ml-2 hidden md:inline-block"
                    onclick="event.stopPropagation()"
                  >
                    {item.demoUrl ? "在线体验" : "查看详情"} &rarr;
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      ) : (
        <div class="col-span-full text-center py-12 text-text-muted animate-on-scroll">
          <p class="font-mono text-sm">// 作品整理中，敬请期待...</p>
        </div>
      )}
    </div>
  </div>
</section>

<script>
  const filterBtns = document.querySelectorAll(".filter-btn");
  const portfolioItems = document.querySelectorAll(".portfolio-item");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      const category = btn.getAttribute("data-category");

      portfolioItems.forEach((item) => {
        const el = item as HTMLElement;
        if (category === "全部" || item.getAttribute("data-category") === category) {
          el.style.display = "";
        } else {
          el.style.display = "none";
        }
      });
    });
  });

  // 卡片点击跳转
  portfolioItems.forEach((item) => {
    item.addEventListener("click", (e) => {
      const url = item.getAttribute("data-url");
      const isExternal = item.getAttribute("data-external") === "true";

      if (url) {
        if (isExternal) {
          window.open(url, "_blank", "noopener,noreferrer");
        } else {
          window.location.href = url;
        }
      }
    });
  });
</script>
