---
import { navItems, profile } from "../data/content";
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="#hero" class="font-mono text-sm font-medium text-primary tracking-wider">
        {profile.name}
      </a>

      <div class="hidden md:flex items-center gap-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="nav-link text-sm font-medium text-text-secondary hover:text-primary"
          >
            {item.label}
          </a>
        ))}
      </div>

      <button
        id="menu-toggle"
        class="md:hidden p-2 rounded-lg hover:bg-surface transition text-text-secondary"
        aria-label="打开菜单"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden bg-bg/95 backdrop-blur-md border-t border-border">
    <div class="px-4 py-3 space-y-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link block px-3 py-2 rounded-lg text-sm font-medium text-text-secondary hover:text-primary hover:bg-surface transition"
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      navbar?.classList.add("bg-bg/90", "backdrop-blur-md", "border-b", "border-border");
    } else {
      navbar?.classList.remove("bg-bg/90", "backdrop-blur-md", "border-b", "border-border");
    }
  });

  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  menuToggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
    });
  });
</script>
