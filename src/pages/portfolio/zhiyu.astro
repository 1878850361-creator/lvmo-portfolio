---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="知愈 - 健康状态追踪 PWA">
  <main class="detail-page min-h-screen pt-24 pb-16">
    <div class="max-w-6xl mx-auto px-6">

      <!-- 返回按钮 -->
      <a href="/#portfolio" class="inline-flex items-center gap-2 text-text-secondary hover:text-primary transition-colors mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        返回首页
      </a>

      <!-- 头部信息 -->
      <div class="mb-12 animate-on-scroll">
        <h1 class="text-4xl font-bold mb-4 gradient-text">知愈 ZhiYu</h1>
        <p class="text-xl text-primary font-medium mb-4">个人健康状态追踪 PWA</p>
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="tag">PWA</span>
          <span class="tag">健康追踪</span>
          <span class="tag">数据可视化</span>
          <span class="tag">离线可用</span>
        </div>
        <p class="text-text-secondary leading-relaxed max-w-3xl">
          知愈是一款轻量级的个人健康状态追踪应用，帮助用户记录每日健康数据、发现身体规律、建立健康习惯。采用 PWA 技术，支持离线使用、安装到桌面，数据完全存储在本地，保护隐私安全。
        </p>
      </div>

      <!-- 手机框架 + iframe -->
      <section class="mb-12 animate-on-scroll delay-100">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="w-1 h-6 bg-gradient-to-b from-primary to-secondary rounded-full"></span>
          在线体验
        </h2>
        <p class="text-text-secondary mb-6">
          点击下方手机框架内的应用进行交互体验，或
          <a href="https://zhiyu-health-tracker.vercel.app" target="_blank" class="text-primary hover:underline">在新窗口打开</a>
        </p>

        <div class="flex justify-center">
          <!-- 手机框架 -->
          <div class="phone-frame">
            <div class="phone-notch"></div>
            <iframe
              src="https://zhiyu-health-tracker.vercel.app"
              class="phone-screen"
              title="知愈 App 演示"
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </section>

      <!-- 核心功能 -->
      <section class="mb-12 animate-on-scroll delay-200">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="w-1 h-6 bg-gradient-to-b from-primary to-secondary rounded-full"></span>
          核心功能
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="rounded-lg bg-surface border border-border p-4 aspect-square flex flex-col items-center justify-center text-center">
            <div class="text-3xl mb-2">📝</div>
            <h3 class="text-sm font-bold mb-1">多维度记录</h3>
            <p class="text-text-secondary text-xs">健康指标追踪</p>
          </div>
          <div class="rounded-lg bg-surface border border-border p-4 aspect-square flex flex-col items-center justify-center text-center">
            <div class="text-3xl mb-2">📊</div>
            <h3 class="text-sm font-bold mb-1">趋势分析</h3>
            <p class="text-text-secondary text-xs">数据可视化</p>
          </div>
          <div class="rounded-lg bg-surface border border-border p-4 aspect-square flex flex-col items-center justify-center text-center">
            <div class="text-3xl mb-2">📅</div>
            <h3 class="text-sm font-bold mb-1">日历回顾</h3>
            <p class="text-text-secondary text-xs">热力图展示</p>
          </div>
          <div class="rounded-lg bg-surface border border-border p-4 aspect-square flex flex-col items-center justify-center text-center">
            <div class="text-3xl mb-2">💾</div>
            <h3 class="text-sm font-bold mb-1">数据导出</h3>
            <p class="text-text-secondary text-xs">备份与迁移</p>
          </div>
        </div>
      </section>

      <!-- 技术栈 -->
      <section class="mb-12 animate-on-scroll delay-300">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="w-1 h-6 bg-gradient-to-b from-primary to-secondary rounded-full"></span>
          技术实现
        </h2>
        <div class="flex flex-wrap gap-2">
          <span class="tag">HTML5</span>
          <span class="tag">CSS3</span>
          <span class="tag">Vanilla JavaScript</span>
          <span class="tag">PWA</span>
          <span class="tag">Service Worker</span>
          <span class="tag">LocalStorage</span>
          <span class="tag">Chart.js</span>
          <span class="tag">Capacitor</span>
        </div>
      </section>

      <!-- 项目亮点 -->
      <section class="mb-12 animate-on-scroll delay-400">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class="w-1 h-6 bg-gradient-to-b from-primary to-secondary rounded-full"></span>
          项目亮点
        </h2>
        <div class="space-y-4">
          <div class="rounded-xl bg-surface border border-border p-6">
            <h3 class="font-bold mb-2 text-primary">🚀 渐进式 Web 应用</h3>
            <p class="text-text-secondary text-sm">采用 PWA 技术，支持离线使用、添加到主屏幕，体验接近原生 App</p>
          </div>
          <div class="rounded-xl bg-surface border border-border p-6">
            <h3 class="font-bold mb-2 text-primary">🔒 隐私优先设计</h3>
            <p class="text-text-secondary text-sm">所有数据存储在本地 LocalStorage，无需注册登录，完全保护用户隐私</p>
          </div>
          <div class="rounded-xl bg-surface border border-border p-6">
            <h3 class="font-bold mb-2 text-primary">📱 跨平台部署</h3>
            <p class="text-text-secondary text-sm">通过 Capacitor 打包为 Android APK，同一套代码支持 Web 与移动端</p>
          </div>
        </div>
      </section>

    </div>
  </main>
</Layout>

<style>
  /* 手机框架样式 */
  .phone-frame {
    position: relative;
    width: 375px;
    height: 667px;
    background: #1a1a1a;
    border-radius: 36px;
    padding: 12px;
    box-shadow:
      0 0 0 2px #2a2a2a,
      0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .phone-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 150px;
    height: 28px;
    background: #1a1a1a;
    border-radius: 0 0 20px 20px;
    z-index: 10;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 28px;
    background: white;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .phone-frame {
      width: 100%;
      max-width: 375px;
      height: 600px;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll(".animate-on-scroll").forEach((el) => {
    observer.observe(el);
  });
</script>
