---
import Layout from "../../layouts/Layout.astro";

// 作品系列数据
const series = [
  {
    title: "2023 年金犊奖 - 旺旺食品",
    category: "品牌设计",
    images: ["work-02.jpg", "work-03.jpg"],
  },
  {
    title: "2023 年春季大广赛 - 雕牌洗衣液",
    category: "创意海报",
    images: ["work-04.jpg", "work-05.jpg", "work-06.jpg"],
  },
  {
    title: "2023 年春季大广赛 - 泡泡玛特",
    category: "品牌设计",
    images: ["work-07.jpg", "work-08.jpg"],
  },
  {
    title: "2023 年春季学院奖 - 雅客食品",
    category: "创意海报",
    images: ["work-09.jpg", "work-10.jpg", "work-11.jpg"],
  },
  {
    title: "摄影作品 - 风光系列 01",
    category: "摄影",
    images: ["work-12.jpg", "work-13.jpg", "work-14.jpg"],
  },
  {
    title: "摄影作品 - 风光系列 02",
    category: "摄影",
    images: ["work-15.jpg", "work-16.jpg"],
  },
  {
    title: "摄影作品 - 风光系列 03",
    category: "摄影",
    images: ["work-17.jpg", "work-18.jpg"],
  },
  {
    title: "摄影作品 - 人像系列 01",
    category: "摄影",
    images: ["work-19.jpg", "work-20.jpg", "work-21.jpg"],
  },
  {
    title: "摄影作品 - 人像系列 02",
    category: "摄影",
    images: ["work-22.jpg", "work-23.jpg"],
  },
  {
    title: "摄影作品 - 人像系列 03",
    category: "摄影",
    images: ["work-24.jpg", "work-25.jpg"],
  },
];
---

<Layout title="平面作品展示">
  <main class="detail-page min-h-screen pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-6">

      <!-- 返回按钮 -->
      <a href="/#portfolio" class="inline-flex items-center gap-2 text-text-secondary hover:text-primary transition-colors mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        返回首页
      </a>

      <!-- 头部信息 -->
      <div class="mb-12 animate-on-scroll">
        <h1 class="text-4xl font-bold mb-4 gradient-text">平面作品展示</h1>
        <p class="text-xl text-primary font-medium mb-4">品牌设计 · 创意海报 · 摄影作品</p>
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="tag">金犊奖</span>
          <span class="tag">大广赛</span>
          <span class="tag">学院奖</span>
          <span class="tag">摄影创作</span>
        </div>
        <p class="text-text-secondary leading-relaxed max-w-3xl">
          精选个人平面设计与摄影作品，涵盖品牌视觉设计、创意海报、风光摄影与人像摄影等多个领域。作品曾参与金犊奖、大广赛、学院奖等专业赛事。
        </p>
      </div>

      <!-- 作品系列 -->
      {series.map((item, idx) => (
        <section class={`mb-16 animate-on-scroll delay-${(idx + 1) * 100}`}>
          <div class="mb-6">
            <h2 class="text-2xl font-bold mb-2 flex items-center gap-3">
              <span class="w-1 h-6 bg-gradient-to-b from-primary to-secondary rounded-full"></span>
              {item.title}
            </h2>
            <span class="text-sm text-text-secondary ml-4">{item.category}</span>
          </div>

          <!-- 图片网格 -->
          <div class={`grid gap-4 ${
            item.images.length === 1 ? "grid-cols-1 max-w-2xl mx-auto" :
            item.images.length === 2 && item.title.includes("泡泡玛特") ? "grid-cols-1 md:grid-cols-2 max-w-4xl mx-auto" :
            item.images.length === 2 ? "grid-cols-1 md:grid-cols-2" :
            "grid-cols-1 md:grid-cols-2 lg:grid-cols-3"
          }`}>
            {item.images.map((img) => (
              <div
                class="rounded-lg overflow-hidden border border-border cursor-pointer hover:border-primary transition-colors group"
                data-lightbox={`/images/design/${img}`}
              >
                <img
                  src={`/images/design/${img}`}
                  alt={item.title}
                  class="w-full h-auto object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </section>
      ))}

    </div>
  </main>

  <!-- Lightbox 弹窗 -->
  <div id="lightbox" class="lightbox">
    <button class="lightbox-close" aria-label="关闭">&times;</button>
    <button class="lightbox-prev" aria-label="上一张">‹</button>
    <button class="lightbox-next" aria-label="下一张">›</button>
    <img id="lightbox-img" src="" alt="" />
    <div class="lightbox-counter"></div>
  </div>
</Layout>

<style>
  .lightbox {
    display: none;
    position: fixed;
    z-index: 10000;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    align-items: center;
    justify-content: center;
    padding: 2rem;
    animation: fadeIn 0.2s;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: white;
    font-size: 3rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.5rem;
    transition: opacity 0.2s;
    z-index: 10001;
  }

  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: white;
    font-size: 3rem;
    cursor: pointer;
    padding: 1rem 1.5rem;
    transition: background 0.2s;
    z-index: 10001;
  }

  .lightbox-prev {
    left: 1rem;
  }

  .lightbox-next {
    right: 1rem;
  }

  .lightbox-prev:hover,
  .lightbox-next:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-close:hover {
    opacity: 0.7;
  }

  #lightbox-img {
    max-width: 85%;
    max-height: 85%;
    object-fit: contain;
    animation: zoomIn 0.3s;
  }

  .lightbox-counter {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: white;
    font-size: 0.875rem;
    background: rgba(0, 0, 0, 0.5);
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes zoomIn {
    from { transform: scale(0.8); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  @media (max-width: 768px) {
    .lightbox-prev,
    .lightbox-next {
      font-size: 2rem;
      padding: 0.5rem 1rem;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll(".animate-on-scroll").forEach((el) => {
    observer.observe(el);
  });

  // Lightbox 功能
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const lightboxClose = document.querySelector(".lightbox-close");
  const lightboxPrev = document.querySelector(".lightbox-prev");
  const lightboxNext = document.querySelector(".lightbox-next");
  const lightboxCounter = document.querySelector(".lightbox-counter");

  let allImages: string[] = [];
  let currentIndex = 0;

  // 收集所有图片
  document.querySelectorAll("[data-lightbox]").forEach((trigger, idx) => {
    const imgSrc = trigger.getAttribute("data-lightbox");
    if (imgSrc) {
      allImages.push(imgSrc);
      trigger.addEventListener("click", () => {
        currentIndex = idx;
        showImage(currentIndex);
        lightbox?.classList.add("active");
      });
    }
  });

  function showImage(index: number) {
    if (lightboxImg && allImages[index]) {
      lightboxImg.src = allImages[index];
      if (lightboxCounter) {
        lightboxCounter.textContent = `${index + 1} / ${allImages.length}`;
      }
    }
  }

  lightboxClose?.addEventListener("click", () => {
    lightbox?.classList.remove("active");
  });

  lightboxPrev?.addEventListener("click", () => {
    currentIndex = (currentIndex - 1 + allImages.length) % allImages.length;
    showImage(currentIndex);
  });

  lightboxNext?.addEventListener("click", () => {
    currentIndex = (currentIndex + 1) % allImages.length;
    showImage(currentIndex);
  });

  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) {
      lightbox.classList.remove("active");
    }
  });

  // 键盘导航
  document.addEventListener("keydown", (e) => {
    if (lightbox?.classList.contains("active")) {
      if (e.key === "Escape") {
        lightbox.classList.remove("active");
      } else if (e.key === "ArrowLeft") {
        currentIndex = (currentIndex - 1 + allImages.length) % allImages.length;
        showImage(currentIndex);
      } else if (e.key === "ArrowRight") {
        currentIndex = (currentIndex + 1) % allImages.length;
        showImage(currentIndex);
      }
    }
  });
</script>
